# App
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=<generate with: node ace generate:key>
APP_URL=http://localhost:3333

# Session
SESSION_DRIVER=memory

# Base de données (correspond au docker-compose.yml)
DATABASE_URL=postgresql://goconcert:goconcert_secret@localhost:5432/goconcert

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# SMS OTP (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Ticketmaster / Browserless
BROWSERLESS_URL=wss://chrome.browserless.io
BROWSERLESS_TOKEN=
DISCORD_WEBHOOK_URL=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Pricing
COMMISSION_RATE=0.10
MIN_PRICE_EUR=2.00
MAX_PRICE_EUR=50.00
BASE_RATE_PER_KM=0.08

# Notifications Expo
EXPO_ACCESS_TOKEN=

# Paiement (stub)
PAYMENT_STUB=true
STRIPE_SECRET_KEY=
